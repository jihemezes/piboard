{
  "id": "quote",
  "version": "0.1.0",
  "name": {
    "en": "Quote of the day",
    "fr": "Citation du jour"
  },
  "titleBar": false,
  "description": {
    "en": "A rotating quote from a bundled offline collection — no internet required.",
    "fr": "Une citation issue d'une collection embarquée hors-ligne — aucune connexion requise."
  },
  "size": {
    "w": 3,
    "h": 1,
    "minW": 1,
    "minH": 1,
    "maxW": 12,
    "maxH": 5
  },
  "settings": [
    {
      "key": "mode",
      "type": "select",
      "default": "daily",
      "label": {
        "en": "Rotation",
        "fr": "Rotation"
      },
      "options": [
        {
          "value": "daily",
          "label": {
            "en": "New quote every day",
            "fr": "Nouvelle citation chaque jour"
          }
        },
        {
          "value": "interval",
          "label": {
            "en": "Rotate on a timer",
            "fr": "Rotation minutée"
          }
        }
      ]
    },
    {
      "key": "intervalMinutes",
      "type": "number",
      "default": 30,
      "min": 1,
      "max": 720,
      "step": 1,
      "label": {
        "en": "Rotate every (minutes)",
        "fr": "Rotation toutes les (minutes)"
      }
    },
    {
      "key": "showAuthor",
      "type": "checkbox",
      "default": true,
      "label": {
        "en": "Show author",
        "fr": "Afficher l'auteur"
      }
    }
  ]
}