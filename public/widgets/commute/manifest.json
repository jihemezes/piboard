        "en": "Extra trip 3 — destination address",
        "fr": "Trajet supplémentaire 3 — adresse de destination"
      },
      "group": {
        "en": "Extra trips",
        "fr": "Trajets supplémentaires"
      }
    },
    {
      "key": "trip4Label",
      "type": "text",
      "default": "",
      "label": {
        "en": "Extra trip 4 — name (e.g. Mom)",
        "fr": "Trajet supplémentaire 4 — nom (ex. Maman)"
      },
      "group": {
        "en": "Extra trips",
        "fr": "Trajets supplémentaires"
      }
    },
    {
      "key": "trip4Address",
      "type": "text",
      "default": "",
      "label": {
        "en": "Extra trip 4 — destination address",
        "fr": "Trajet supplémentaire 4 — adresse de destination"
      },
      "group": {
        "en": "Extra trips",
        "fr": "Trajets supplémentaires"
      }
    },
    {
      "key": "trip5Label",
      "type": "text",
      "default": "",
      "label": {
        "en": "Extra trip 5 — name (e.g. Mom)",
        "fr": "Trajet supplémentaire 5 — nom (ex. Maman)"
      },
      "group": {
        "en": "Extra trips",
        "fr": "Trajets supplémentaires"
      }
    },
    {
      "key": "trip5Address",
      "type": "text",
      "default": "",
      "label": {
        "en": "Extra trip 5 — destination address",
        "fr": "Trajet supplémentaire 5 — adresse de destination"
      },
      "group": {
        "en": "Extra trips",
        "fr": "Trajets supplémentaires"
      }
    },
    {
      "key": "refresh",
      "type": "number",
      "default": 10,
      "min": 5,
      "max": 60,
      "step": 5,
      "label": {
        "en": "Refresh (minutes)",
        "fr": "Rafraîchissement (minutes)"
      },
