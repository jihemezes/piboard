{
  "id": "crypto",
  "version": "0.2.0",
  "name": {
    "en": "Crypto prices",
    "fr": "Cours de cryptos"
  },
  "titleBar": false,
  "description": {
    "en": "Live prices and 24h change for a few coins, powered by CoinGecko (no API key). Tap a coin to see its price chart (24h / 7d / 30d / 1y).",
    "fr": "Cours en direct et variation 24h de quelques cryptomonnaies, via CoinGecko (sans clé API). Touchez une crypto pour voir sa courbe (24h / 7j / 30j / 1an)."
  },
  "size": {
    "w": 3,
    "h": 2,
    "minW": 1,
    "minH": 1,
    "maxW": 6,
    "maxH": 6
  },
  "settings": [
    {
      "key": "coins",
      "type": "text",
      "default": "bitcoin,ethereum",
      "label": {
        "en": "Coins (CoinGecko ids, comma-separated)",
        "fr": "Cryptos (identifiants CoinGecko, séparés par des virgules)"
      }
    },
    {
      "key": "currency",
      "type": "select",
      "default": "eur",
      "label": {
        "en": "Currency",
        "fr": "Devise"
      },
      "options": [
        {
          "value": "eur",
          "label": {
            "en": "Euro (€)",
            "fr": "Euro (€)"
          }
        },
        {
          "value": "usd",
          "label": {
            "en": "US Dollar ($)",
            "fr": "Dollar US ($)"
          }
        }
      ]
    },
    {
      "key": "refresh",
      "type": "number",
      "default": 5,
      "min": 1,
      "max": 60,
      "step": 1,
      "label": {
        "en": "Refresh (minutes)",
        "fr": "Rafraîchissement (minutes)"
      }
    }
  ]
}